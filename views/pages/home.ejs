<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BilupTheme - Share Your Themes</title>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

    <link rel="stylesheet" href="/static/css/styles.css">
    <style>
        body { background: var(--bg-color); }
        .hero { text-align: center; padding: 6rem 2rem 4rem; max-width: 900px; margin: 0 auto; }
        .hero h1 { font-size: 4.5rem; font-weight: 800; margin-bottom: 1.5rem; color: var(--primary-color); }
        .hero p { font-size: 1.4rem; color: var(--text-light); margin-bottom: 2.5rem; line-height: 1.8; max-width: 700px; margin-left: auto; margin-right: auto; }
        .hero .cta-container { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
        .hero .btn { padding: 1rem 2.5rem; font-size: 1.1rem; font-weight: 600; }
        .features-section { max-width: 1200px; margin: 4rem auto; padding: 0 2rem; text-align: center; }
        .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 3rem; }
        .feature-card { background: var(--card-bg); border-radius: 16px; padding: 2rem; transition: var(--transition); text-align: center; }
        .feature-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
        .feature-icon { width: 56px; height: 56px; background: var(--primary-color); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; }
        .feature-icon i { width: 28px; height: 28px; color: white; }
        .feature-card h3 { font-size: 1.35rem; margin-bottom: 0.75rem; color: var(--text-color); font-weight: 700; }
        .feature-card p { color: var(--text-light); line-height: 1.7; font-size: 0.95rem; }
        .section-title { text-align: center; font-size: 2.5rem; margin-bottom: 0.75rem; color: var(--text-color); font-weight: 700; }
        .section-subtitle { text-align: center; color: var(--text-light); font-size: 1.1rem; }
        .auth-cta { max-width: 800px; margin: 6rem auto; padding: 3.5rem 2.5rem; background: var(--card-bg); border-radius: 24px; text-align: center; }
        .auth-cta h2 { font-size: 2rem; margin-bottom: 1rem; color: var(--text-color); font-weight: 700; }
        .auth-cta p { color: var(--text-light); font-size: 1.1rem; margin-bottom: 2rem; background: var(--bg-color); padding: 0.75rem 1.5rem; border-radius: 10px; display: inline-block; }
        .auth-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
        .auth-btn { display: flex; align-items: center; gap: 0.75rem; padding: 1rem 2rem; border-radius: 12px; text-decoration: none; font-weight: 600; font-size: 1rem; transition: var(--transition); }
        .auth-btn.rotur { background: var(--primary-color); color: white; }
        .auth-btn.rotur:hover { background: var(--primary-light); transform: translateY(-2px); }
        .auth-btn.scratch { background: var(--card-bg); color: var(--text-color); }
        .auth-btn.scratch:hover { color: var(--text-color); }
        @media (max-width: 768px) {
            .hero { padding: 4rem 1.5rem 2.5rem; }
            .hero h1 { font-size: 2.8rem; }
            .hero p { font-size: 1.15rem; }
            .auth-btn { width: 100%; justify-content: center; }
            .auth-cta { padding: 2.5rem 1.5rem; }
        }
    </style>
</head>
<body>
    <%- include('../partials/nav', { ...locals }) %>

    <main>
        <section class="hero">
            <h1>BilupTheme</h1>
            <p>The ultimate theme marketplace for your favorite mods. Create, share, and discover beautiful themes across multiple platforms.</p>
            <div class="cta-container">
                <a href="/upload" class="btn primary">
                    <i data-lucide="palette"></i>
                    Create Theme
                </a>
                <a href="/themes" class="btn secondary">
                    <i data-lucide="search"></i>
                    Browse Themes
                </a>
            </div>
        </section>

        <section class="features-section">
            <h2 class="section-title">Why BilupTheme?</h2>
            <p class="section-subtitle">Everything you need to customize your experience</p>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon"><i data-lucide="layers"></i></div>
                    <h3>Cross-Platform Support</h3>
                    <p>Upload themes once and use them across multiple mods including MistWarp and NitroBolt. Seamlessly convert between different formats.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i data-lucide="lock"></i></div>
                    <h3>Secure Auth</h3>
                    <p>Sign in with Scratch or Rotur for secure authentication. Your themes are protected and your identity is verified.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i data-lucide="heart"></i></div>
                    <h3>Community Driven</h3>
                    <p>Like and download themes from the community. Discover trending themes and see what's popular with built-in rating system.</p>
                </div>
            </div>
        </section>

        <section class="auth-cta">
            <h2>Start Creating Today</h2>
            <div class="auth-buttons">
                <% if (Authenticated) { %>
                    <a href="/upload" class="auth-btn rotur">
                        <i data-lucide="upload"></i>
                        Upload Your Theme
                    </a>
                <% } else { %>
                    <a href="/auth" class="auth-btn rotur">
                        <i data-lucide="user"></i>
                        Sign In with Rotur/Scratch
                    </a>
                <% } %>
                <a href="/themes" class="auth-btn scratch" style="background: var(--card-bg); color: var(--text-color);">
                    <i data-lucide="search"></i>
                    Browse All Themes
                </a>
            </div>
        </section>
    </main>

    <%- include('../partials/footer', { ...locals }) %>

    <script src="/static/js/main.js"></script>
    <script>lucide.createIcons();</script>
</body>
</html>
